# =========================
# ==== DATABASE (DEV) =====
# =========================
# Se quiser usar SQLite no dev, descomente a linha abaixo e comente a do Postgres.
# DATABASE_URL=sqlite:///./eduinclusiva.db

# Você já tem um Postgres no Supabase; pode usar também no DEV:
# ✅ DICA: Supabase geralmente exige SSL. Acrescente ?sslmode=require no final.
DATABASE_URL=postgresql+psycopg2://postgres:nQfLFcUbwVRLo1jf@db.ombmhlqkyymdmtofoyok.supabase.co:5432/postgres?sslmode=require

# =========================
# ======= OPENAI ==========
# =========================
OPENAI_API_KEY=sk-xxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =========================
# ==== VECTOR STORE =======
# =========================
# (deixe comentado se não for usar agora)
# QDRANT_URL=https://<host>:6333
# QDRANT_API_KEY=<sua_key>
VECTOR_COLLECTION=eduinclusiva

# =========================
# ======= STORAGE =========
# =========================
# No dev local, a pasta ./uploads funciona bem.
UPLOAD_DIR=./uploads

# =========================
# ======= SECURITY ========
# =========================
# Mantive seus nomes originais (SECRET_KEY e ACCESS_TOKEN_EXPIRE_MINUTES)
# porque o seu auth.py provavelmente os usa.
SECRET_KEY=umasecretkeymuitosegura
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =========================
# ======== CORS ===========
# =========================
# O main.py lê ALLOWED_ORIGINS, ALLOW_ORIGIN_REGEX e ALLOW_ALL_ORIGINS.
# No DEV, liberei localhost e (opcionalmente) seu domínio da Vercel para testar “cross”.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://frontend-eduinclusiva-v1-<hash>-oleonardomendes-projects.vercel.app
# Alternativas (não use as duas ao mesmo tempo):
# ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app$
# ALLOW_ALL_ORIGINS=true   # use APENAS para depuração

# =========================
# ======== MODE ===========
# =========================
ENV=development